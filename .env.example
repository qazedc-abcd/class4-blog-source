# ===== ClassMemorial 配置 =====
# 复制为 .env 后填写。所有带 * 的项必须设置。

# ---------- 站点 ----------
SITE_TITLE=班级纪念站

# ---------- 管理后台登录 ----------
# 方式 A（推荐）：用 scripts/hash_password.py 生成 hash，填到这里
ADMIN_PASSWORD_HASH=
# 方式 B（仅本地调试）：明文密码
ADMIN_PASSWORD=changeme
# JWT 密钥：随便填一串长随机字符（生产务必更换）
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_TTL_HOURS=168

# ---------- GitHub 双向同步 ----------
# 仓库地址（不含 https），如 qazedc-abcd/class4-blog-source
GITHUB_REPO=qazedc-abcd/class4-blog-source
GITHUB_BRANCH=main
# Personal Access Token，需要 repo 权限（用于后台编辑后推送）
GITHUB_TOKEN=
# Webhook 共享密钥（GitHub 仓库 Settings → Webhooks 里填同一个）
GITHUB_WEBHOOK_SECRET=
GIT_AUTHOR_NAME=ClassMemorial Bot
GIT_AUTHOR_EMAIL=bot@classmemorial.local
# 设为 false 可临时关闭同步（仅本地编辑）
SYNC_ENABLED=true

# ---------- Cloudflare R2（图片存储）----------
# 在 Cloudflare 控制台 → R2 → 你的桶 → Settings 拿到这些值
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=class4
# 绑定到桶的公开访问域名（带路径前缀），如 https://drive.zichenccc.cn/raw
R2_PUBLIC_BASE=https://drive.zichenccc.cn/raw

# ---------- uvicorn ----------
UVICORN_WORKERS=1
